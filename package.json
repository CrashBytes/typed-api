{
  "name": "@crashbytes/typed-api",
  "version": "1.0.2",
  "description": "Type-safe API client builder with full TypeScript inference. Define routes with schemas, get compile-time safety. Zero dependencies.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "api",
    "client",
    "type-safe",
    "typescript",
    "inference",
    "rest",
    "fetch",
    "schema",
    "builder",
    "trpc"
  ],
  "author": "CrashBytes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CrashBytes/typed-api.git"
  },
  "bugs": {
    "url": "https://github.com/CrashBytes/typed-api/issues"
  },
  "homepage": "https://github.com/CrashBytes/typed-api#readme",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
